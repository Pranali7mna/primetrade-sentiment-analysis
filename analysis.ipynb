import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

plt.style.use('default')
sns.set_theme()

pd.set_option('display.max_columns', None)
fear = pd.read_csv("../data/fear_greed_index.csv")
trades = pd.read_csv("../data/historical_data.csv")

print("Fear Shape:", fear.shape)
print("Trades Shape:", trades.shape)
trades['Date'] = pd.to_datetime(
    trades['Timestamp IST'],
    dayfirst=True
).dt.date

fear['Date'] = pd.to_datetime(
    fear['date']
).dt.date
merged_df = trades.merge(
    fear[['Date','classification','value']],
    on='Date',
    how='left'
)

merged_df = merged_df.dropna(
    subset=['classification']
)

print(merged_df.shape)
merged_df = trades.merge(
    fear[['Date','classification','value']],
    on='Date',
    how='left'
)

merged_df = merged_df.dropna(
    subset=['classification']
)

print(merged_df.shape)
print("\nMissing Values")
print(merged_df.isnull().sum())

print("\nSentiment Distribution")
print(
    merged_df['classification']
    .value_counts()
)
sentiment_pnl = (
    merged_df.groupby('classification')
    ['Closed PnL']
    .mean()
    .sort_values(ascending=False)
)

print(sentiment_pnl)
plt.figure(figsize=(10,5))

sns.barplot(
    x=sentiment_pnl.index,
    y=sentiment_pnl.values
)

plt.title("Average Closed PnL by Sentiment")
plt.xlabel("Market Sentiment")
plt.ylabel("Average Closed PnL")

plt.xticks(rotation=20)

plt.tight_layout()

plt.savefig(
    "../images/pnl_by_sentiment.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
merged_df['Win'] = merged_df['Closed PnL'] > 0

print(merged_df[['Closed PnL','Win']].head())
win_rate = (
    merged_df.groupby('classification')
    ['Win']
    .mean()*100
)

print(win_rate)
plt.figure(figsize=(10,5))

sns.barplot(
    x=win_rate.index,
    y=win_rate.values
)

plt.title("Win Rate (%) by Sentiment")
plt.xlabel("Market Sentiment")
plt.ylabel("Win Rate (%)")

plt.xticks(rotation=20)

plt.tight_layout()

plt.savefig(
    "../images/win_rate_by_sentiment.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
trade_count = (
    merged_df.groupby('classification')
    .size()
)

print(trade_count)
plt.figure(figsize=(10,5))

sns.barplot(
    x=trade_count.index,
    y=trade_count.values
)

plt.title("Trade Count by Sentiment")
plt.xlabel("Market Sentiment")
plt.ylabel("Number of Trades")

plt.xticks(rotation=20)

plt.tight_layout()

plt.savefig(
    "../images/trade_count_by_sentiment.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
fee_analysis = (
    merged_df.groupby('classification')
    ['Fee']
    .mean()
)

print(fee_analysis)
plt.figure(figsize=(10,5))

sns.barplot(
    x=fee_analysis.index,
    y=fee_analysis.values
)

plt.title("Average Fee by Sentiment")
plt.xlabel("Market Sentiment")
plt.ylabel("Average Fee")

plt.xticks(rotation=20)

plt.tight_layout()

plt.savefig(
    "../images/fee_by_sentiment.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
coin_profit = (
    merged_df.groupby('Coin')
    ['Closed PnL']
    .sum()
    .sort_values(ascending=False)
)

print(
    coin_profit.head(10)
)
plt.figure(figsize=(12,5))

coin_profit.head(10).plot(
    kind='bar'
)

plt.title("Top 10 Coins by Total Profit")
plt.xlabel("Coin")
plt.ylabel("Total Closed PnL")

plt.tight_layout()

plt.savefig(
    "../images/top_profitable_coins.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
top_coins = (
    merged_df['Coin']
    .value_counts()
    .head(10)
)

print(top_coins)
plt.figure(figsize=(12,5))

top_coins.plot(
    kind='bar'
)

plt.title("Top 10 Most Traded Coins")
plt.xlabel("Coin")
plt.ylabel("Number of Trades")

plt.tight_layout()

plt.savefig(
    "../images/top_traded_coins.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
corr = merged_df[
    ['Closed PnL','Fee','Size USD']
].corr()

print(corr)
plt.figure(figsize=(8,6))

sns.heatmap(
    corr,
    annot=True,
    cmap='coolwarm'
)

plt.title("Correlation Heatmap")

plt.tight_layout()

plt.savefig(
    "../images/correlation_heatmap.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
top_traders = (
    merged_df.groupby('Account')
    ['Closed PnL']
    .sum()
    .sort_values(ascending=False)
)

print(
    top_traders.head(10)
)
plt.figure(figsize=(12,5))

top_traders.head(10).plot(
    kind='bar'
)

plt.title("Top 10 Profitable Traders")
plt.xlabel("Trader Account")
plt.ylabel("Total Closed PnL")

plt.tight_layout()

plt.savefig(
    "../images/top_profitable_traders.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
plt.figure(figsize=(12,6))

sns.boxplot(
    data=merged_df,
    x='classification',
    y='Closed PnL'
)

plt.title(
    "Profit Distribution by Sentiment"
)

plt.xticks(rotation=20)

plt.show()
plt.figure(figsize=(12,6))

sns.boxplot(
    data=merged_df,
    x='classification',
    y='Closed PnL'
)

plt.title("Profit Distribution by Sentiment")
plt.xlabel("Market Sentiment")
plt.ylabel("Closed PnL")

plt.xticks(rotation=20)

plt.tight_layout()

plt.savefig(
    "../images/profit_distribution_boxplot.png",
    dpi=300,
    bbox_inches='tight'
)

plt.show()
